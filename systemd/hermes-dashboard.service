[Unit]
Description=Hermes Agent Dashboard
After=network.target

[Service]
Type=simple
User=droidian
WorkingDirectory=/home/droidian/hermes-agent
ExecStart=/home/droidian/hermes-agent/venv/bin/hermes dashboard --host 0.0.0.0 --port 3000 --no-open --skip-build --insecure
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
